# ============================================================
# CONFIGURACIÓN DEL SISTEMA DE AUTOMATIZACIÓN DE DROPSHIPPING
# ============================================================
# Copia este archivo a .env y completa con tus credenciales reales

# APIs de Inteligencia Artificial
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# Meta Ads (Facebook/Instagram)
META_ACCESS_TOKEN=EAAyour-meta-access-token-here
META_AD_ACCOUNT_ID=act_123456789

# Deployment (Vercel/Netlify)
VERCEL_TOKEN=your-vercel-token-here
VERCEL_TEAM_ID=team_optional_if_using_team

# Configuración de Negocio
MIN_PROFIT_MARGIN=3.0  # Margen mínimo requerido (3X = 300%)
DAILY_AD_BUDGET=5.0    # Presupuesto diario en USD para testing

# Dropi Chile Integration (Fulfillment)
DROPI_API_KEY=your-dropi-api-key-here
DROPI_PRODUCT_ID=123456  # ID del producto en el catálogo de Dropi Chile

# WhatsApp CRM Integration
WHATSAPP_PROVIDER=mock  # mock, evolution, o twilio
WHATSAPP_API_URL=https://api.whatsapp-gateway.com
WHATSAPP_API_TOKEN=your-whatsapp-token-here
WHATSAPP_INSTANCE=your-whatsapp-instance-name
WHATSAPP_PHONE_NUMBER_ID=your-twilio-phone-number-id

# Database Integration (PostgreSQL / Supabase - Requerido para Vercel)
# DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Webhooks y Alertas
EMERGENCY_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
